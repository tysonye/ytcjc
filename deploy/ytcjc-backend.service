[Unit]
Description=YTCJC Backend API Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ytcjc/backend
Environment=PATH=/opt/ytcjc/backend/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/opt/ytcjc/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
