[Unit]
Description=YTCJC Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/www/wwwroot/backend
Environment=PATH=/www/wwwroot/backend/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/www/wwwroot/backend/venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
