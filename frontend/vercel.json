{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/titan-proxy/jc/:path*",
      "destination": "/api/proxy?url=https://jc.titan007.com/:path*"
    },
    {
      "source": "/titan-proxy/zq/:path*",
      "destination": "/api/proxy?url=https://zq.titan007.com/:path*"
    },
    {
      "source": "/titan-proxy/vip/:path*",
      "destination": "/api/proxy?url=https://vip.titan007.com/:path*"
    },
    {
      "source": "/500-proxy/:path*",
      "destination": "/api/proxy?url=https://odds.500.com/:path*"
    },
    {
      "source": "/titan-proxy/info/:path*",
      "destination": "/api/proxy?url=https://info.titan007.com/:path*"
    },
    {
      "source": "/macau-proxy/:path*",
      "destination": "/api/proxy?url=https://www.macauslot.com/:path*"
    },
    {
      "source": "/sporttery-proxy/:path*",
      "destination": "/api/proxy?url=https://webapi.sporttery.cn/:path*"
    }
  ]
}
